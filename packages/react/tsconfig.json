{
  "compilerOptions": {
    "strict": true,
    "allowJs": true,
    "sourceMap": true,
    "declaration": true,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "skipLibCheck": false,
    "target": "es6",
    "jsx": "react-jsx",
    "lib": ["dom", "esnext"],
    "outDir": "./dist",
    "module": "commonjs",
    "moduleResolution": "node",
  },
  "include": ["./src"]
}
